# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agency_os

# Authentication
NEXTAUTH_SECRET=your-secret-key-here-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# Cron Jobs
CRON_SECRET=your_cron_secret_key

# SMTP Configuration (MailHog for local dev)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@agencyos.dev

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=your-r2-access-key
R2_SECRET_ACCESS_KEY=your-r2-secret-key
R2_ENDPOINT=https://your-account.r2.cloudflarestorage.com
R2_PUBLIC_URL=https://your-public-url.r2.dev
R2_BUCKET_NAME=agency-os-dev
R2_REGION=auto

# Application URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Payment Providers - Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_test_...

# Payment Providers - Razorpay
RAZORPAY_KEY_ID=rzp_test_...
RAZORPAY_KEY_SECRET=...
RAZORPAY_WEBHOOK_SECRET=...

# Payment Providers - Fonepay
FONEPAY_MERCHANT_CODE=...
FONEPAY_MERCHANT_SECRET=...

# Geolocation (optional, uses geoip-lite if not set)
MAXMIND_LICENSE_KEY=...
